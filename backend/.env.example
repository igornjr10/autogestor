# =====================================================================
# BANCO DE DADOS (PostgreSQL)
# Escolha UMA das opções abaixo. As migrations usam DIRECT_URL; a
# aplicação em runtime usa DATABASE_URL.
# =====================================================================

# --- Opção A: PostgreSQL LOCAL ---------------------------------------
# Use a mesma string nas duas variáveis.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gestao_veiculos?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/gestao_veiculos?schema=public"

# --- Opção B: SUPABASE -----------------------------------------------
# Pegue as strings em: Project Settings > Database > Connection string.
# DATABASE_URL = Pooler (Transaction, porta 6543) + ?pgbouncer=true
# DIRECT_URL   = Direct connection (porta 5432), usada pelas migrations.
# Substitua SEU_REF, SENHA e REGIAO. Faça URL-encode de caracteres
# especiais da senha. Adicione &sslmode=require se necessário.
#
# DATABASE_URL="postgresql://postgres.SEU_REF:SENHA@aws-0-REGIAO.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.SEU_REF:SENHA@aws-0-REGIAO.pooler.supabase.com:5432/postgres"

# =====================================================================
# JWT
# =====================================================================
# Segredos JWT (troque por valores aleatórios fortes em produção)
JWT_SECRET="troque-este-segredo-de-acesso"
JWT_REFRESH_SECRET="troque-este-segredo-de-refresh"

# Expiração dos tokens
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# =====================================================================
# WHATSAPP via DATAFY API (RF-05) — opcional
# Espelho da Meta Cloud API. Conecte um número em app.datafyapi.com.br e
# copie o token sk_live_xxx. Sem o token, as notificações são SIMULADAS.
# =====================================================================
DATAFY_API_URL="https://cloud.datafyapi.com.br"
# DATAFY_API_TOKEN="sk_live_xxx"

# =====================================================================
# CONSULTAS VEICULARES — Consultar Placa (dados do veículo + FIPE)
# Auth Basic: email = usuário, API Key = senha (app.consultarplaca.com.br > API).
# Sem credenciais, as consultas por placa retornam dados SIMULADOS.
# =====================================================================
CONSULTARPLACA_API_URL="https://api.consultarplaca.com.br/v2"
# CONSULTARPLACA_EMAIL="seu-email"
# CONSULTARPLACA_APIKEY="sua-api-key"

# =====================================================================
# CONSULTAS DE CPF/CNPJ (API Brasil) — opcional
# Se ausentes, as consultas retornam dados SIMULADOS (simulado: true).
# Configure para usar a API real (apibrasil.com.br).
# Obs.: a API Brasil usa um DeviceToken por serviço; se os tokens de
# "dados" e "débitos" forem diferentes no seu plano, ajuste o provider.
# =====================================================================
# APIBRASIL_BASE_URL="https://gateway.apibrasil.io/api/v2"
# APIBRASIL_BEARER_TOKEN="seu-bearer-token"
# APIBRASIL_DEVICE_TOKEN="seu-device-token"

# =====================================================================
# ALERTAS AUTOMÁTICOS (cron) — RF-05
# Roda diariamente às 8h: estoque parado +60d, documentos pendentes e
# parcelas a vencer/vencidas. Defina como false para desativar.
# =====================================================================
ALERTAS_CRON_ENABLED="true"

# =====================================================================
# SERVIDOR
# =====================================================================
# Porta da API e origem permitida para CORS (frontend)
PORT=3000
CORS_ORIGIN="http://localhost:5173"
